{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/change-catalog.schema.json",
  "title": "ops/change-catalog.yml schema (L2.5 Service)",
  "description": "Validates ops/change-catalog.yml — параметры стандартных/нестандартных изменений",
  "type": "object",
  "required": ["metadata", "parameters"],
  "additionalProperties": false,
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["service_code", "version", "last_updated"],
      "additionalProperties": true,
      "properties": {
        "service_code": { "type": "string", "minLength": 1 },
        "version":      { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "last_updated": { "type": "string", "format": "date" }
      }
    },
    "change_period_months":        { "type": "number", "minimum": 1 },
    "non_standard_review_workdays":{ "type": "number", "minimum": 1 },
    "non_standard_max_months":     { "type": "number", "minimum": 1 },
    "billing_rules": {
      "type": "object",
      "properties": {
        "increase_in_period":  { "type": "string" },
        "decrease_in_period":  { "type": "string" },
        "deferred_allowed":    { "type": "boolean" }
      }
    },
    "parameters": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/change_parameter" }
    }
  },
  "$defs": {
    "change_parameter": {
      "type": "object",
      "required": ["name", "standard_change"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "standard_change": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "type":      { "type": "string", "enum": ["percent", "absolute"] },
            "value":     { "type": "number", "minimum": 0 },
            "max_limit": { "type": ["number", "null"] },
            "max_limit_unit": { "type": "string" },
            "unlimited": { "type": "boolean" }
          }
        }
      }
    }
  }
}
