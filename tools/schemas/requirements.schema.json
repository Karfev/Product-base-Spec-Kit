{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/requirements.schema.json",
  "title": "requirements.yml schema",
  "type": "object",
  "required": ["metadata", "requirements"],
  "additionalProperties": false,
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["initiative", "product", "owner", "profile", "version", "last_updated"],
      "additionalProperties": true,
      "properties": {
        "initiative": { "type": "string", "pattern": "^INIT-[0-9]{4}-[0-9]{3}-[a-z0-9-]+$" },
        "product":    { "type": "string", "minLength": 1 },
        "owner":      { "type": "string", "minLength": 1 },
        "profile":    { "type": "string", "enum": ["minimal", "standard", "extended", "enterprise"] },
        "version":    { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(-[0-9A-Za-z.-]+)?$" },
        "last_updated": { "type": "string", "format": "date" },
        "classification": {
          "type": "object",
          "description": "Классификационные коды подсистемы по онтологии АИС (domains/is-ontology/canonical-model/model.md)",
          "additionalProperties": false,
          "properties": {
            "system_scale": {
              "type": "string",
              "enum": ["С.М.М", "С.М.С", "С.М.Б"],
              "description": "Масштаб системы: М — малая (<10M LOC), С — средняя (10–100M LOC), Б — большая (>100M LOC)"
            },
            "subsystem_type": {
              "type": "string",
              "enum": ["ПС.Т.И", "ПС.Т.ПТ", "ПС.Т.П"],
              "description": "Тип подсистемы: И — инфраструктурная, ПТ — программно-технологическая, П — прикладная"
            },
            "subsystem_owner": {
              "type": "string",
              "minLength": 1,
              "description": "Владелец подсистемы (team или person handle)"
            },
            "activity_domain": {
              "type": "string",
              "minLength": 1,
              "description": "Вид деятельности / предметная область подсистемы"
            }
          }
        }
      }
    },
    "requirements": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/requirement" }
    }
  },
  "$defs": {
    "requirement": {
      "type": "object",
      "required": ["id", "title", "type", "priority", "status", "description", "trace"],
      "additionalProperties": false,
      "properties": {
        "id":          { "type": "string", "pattern": "^REQ-[A-Z0-9]{2,16}-[0-9]{3}$" },
        "title":       { "type": "string", "minLength": 3 },
        "type": {
          "type": "string",
          "enum": ["functional", "nfr", "quality", "constraint", "compliance"],
          "description": "quality — характеристика качества по ГОСТ Р ИСО/МЭК 25020; требует metrics с iso_characteristic"
        },
        "priority":    { "type": "string", "enum": ["P0", "P1", "P2", "P3"] },
        "status":      { "type": "string", "enum": ["draft", "proposed", "approved", "implemented", "verified", "deprecated"] },
        "description": { "type": "string", "minLength": 10 },
        "acceptance_criteria": {
          "type": "array",
          "items": { "type": "string", "minLength": 5 }
        },
        "metrics": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "target", "measurement"],
            "additionalProperties": false,
            "properties": {
              "name":        { "type": "string", "minLength": 2 },
              "target":      { "type": ["number", "string"] },
              "measurement": { "type": "string", "minLength": 2 },
              "iso_characteristic": {
                "type": "string",
                "enum": [
                  "functional_suitability",
                  "performance_efficiency",
                  "compatibility",
                  "usability",
                  "reliability",
                  "security",
                  "maintainability",
                  "portability"
                ],
                "description": "Характеристика качества по ГОСТ Р ИСО/МЭК 25020-2023"
              },
              "iso_sub_characteristic": {
                "type": "string",
                "description": "Подхарактеристика качества (например: time_behaviour, availability, confidentiality)"
              }
            }
          }
        },
        "trace": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "prd":       { "type": "string" },
            "adr":       { "type": "array", "items": { "type": "string" } },
            "contracts": { "type": "array", "items": { "type": "string" } },
            "schemas":   { "type": "array", "items": { "type": "string" } },
            "tests":     { "type": "array", "items": { "type": "string" } },
            "slo":       { "type": "string" },
            "components":{ "type": "array", "items": { "type": "string" } },
            "architecture_views": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Ссылки на архитектурные представления в design.md (например: design.md#д-1, design.md#п-1)"
            }
          }
        }
      },
      "allOf": [
        {
          "if":   { "properties": { "type": { "const": "functional" } } },
          "then": { "required": ["acceptance_criteria"] }
        },
        {
          "if":   { "properties": { "type": { "const": "nfr" } } },
          "then": { "required": ["metrics"] }
        },
        {
          "if":   { "properties": { "type": { "const": "quality" } } },
          "then": { "required": ["metrics"] }
        }
      ]
    }
  }
}
