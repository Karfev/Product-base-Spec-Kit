{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/incident-catalog.schema.json",
  "title": "ops/incident-catalog.yml schema (L2.5 Service)",
  "description": "Validates ops/incident-catalog.yml — классификация инцидентов, пороги и SLT",
  "type": "object",
  "required": ["metadata", "incidents"],
  "additionalProperties": false,
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["service_code", "version", "last_updated"],
      "additionalProperties": true,
      "properties": {
        "service_code": { "type": "string", "minLength": 1 },
        "version":      { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "last_updated": { "type": "string", "format": "date" }
      }
    },
    "business_hours": {
      "type": "object",
      "properties": {
        "timezone": { "type": "string" },
        "schedule": { "type": "string" }
      }
    },
    "incidents": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/incident_priority" }
    },
    "unavailability_conditions": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "incident_priority": {
      "type": "object",
      "required": ["priority", "description", "thresholds", "slt"],
      "additionalProperties": false,
      "properties": {
        "priority":    { "type": "integer", "minimum": 1, "maximum": 10 },
        "description": { "type": "string", "minLength": 5 },
        "thresholds": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["metric", "condition"],
            "additionalProperties": false,
            "properties": {
              "metric":    { "type": "string", "minLength": 1 },
              "condition": { "type": "string", "minLength": 1 }
            }
          }
        },
        "slt": {
          "type": "object",
          "required": ["reaction_minutes", "resolution_hours", "processing"],
          "additionalProperties": false,
          "properties": {
            "reaction_minutes":  { "type": "number", "minimum": 0 },
            "resolution_hours":  { "type": "number", "minimum": 0 },
            "processing":        { "type": "string", "enum": ["24x7", "business_hours"] }
          }
        }
      }
    }
  }
}
