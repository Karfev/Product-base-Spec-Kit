{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/billing-parameters.schema.json",
  "title": "billing/parameters.yml schema (L2.5 Service)",
  "description": "Validates billing/parameters.yml — тарифицируемые параметры и лимиты изменений",
  "type": "object",
  "required": ["metadata", "groups"],
  "additionalProperties": false,
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["service_code", "version", "last_updated"],
      "additionalProperties": true,
      "properties": {
        "service_code":    { "type": "string", "minLength": 1 },
        "version":         { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "last_updated":    { "type": "string", "format": "date" },
        "billing_period":  { "type": "string", "enum": ["monthly", "quarterly", "annual"] }
      }
    },
    "change_period_months":          { "type": "number", "minimum": 1 },
    "non_standard_review_days":      { "type": "number", "minimum": 1 },
    "non_standard_max_months":       { "type": "number", "minimum": 1 },
    "groups": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/group" }
    }
  },
  "$defs": {
    "group": {
      "type": "object",
      "required": ["group", "parameters"],
      "additionalProperties": false,
      "properties": {
        "group":      { "type": "string", "minLength": 1 },
        "parameters": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/parameter" }
        }
      }
    },
    "parameter": {
      "type": "object",
      "required": ["name", "unit"],
      "additionalProperties": false,
      "properties": {
        "name":  { "type": "string", "minLength": 1 },
        "unit":  { "type": "string", "minLength": 1 },
        "step":  { "type": "number", "minimum": 0 },
        "min":   { "type": "number" },
        "max":   { "type": "number" },
        "standard_change": { "$ref": "#/$defs/standard_change" }
      }
    },
    "standard_change": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "pct":         { "type": "number", "minimum": 0, "maximum": 100 },
        "max_value":   { "type": ["number", "null"] },
        "max_items":   { "type": ["number", "null"] },
        "unit":        { "type": "string" },
        "unlimited":   { "type": "boolean" }
      }
    }
  }
}
