{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/responsibilities.schema.json",
  "title": "responsibilities.yml schema (L2.5 Service)",
  "description": "Validates responsibilities.yml — матрица ответственности по архитектурным блокам и КТС",
  "type": "object",
  "required": ["metadata", "architectural_blocks"],
  "additionalProperties": false,
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["service_code", "version", "last_updated"],
      "additionalProperties": true,
      "properties": {
        "service_code": { "type": "string", "minLength": 1 },
        "version":      { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "last_updated": { "type": "string", "format": "date" }
      }
    },
    "architectural_blocks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/block" }
    },
    "kts_components": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "operate", "transform"],
        "additionalProperties": false,
        "properties": {
          "name":      { "type": "string", "minLength": 1 },
          "operate":   { "type": "string", "minLength": 1 },
          "transform": { "type": "string", "minLength": 1 }
        }
      }
    }
  },
  "$defs": {
    "block": {
      "type": "object",
      "required": ["name", "responsible", "operate", "transform"],
      "additionalProperties": false,
      "properties": {
        "name":        { "type": "string", "minLength": 1 },
        "responsible": { "type": "string", "minLength": 1 },
        "operate":     { "type": "string", "minLength": 1 },
        "transform":   { "type": "string", "minLength": 1 }
      }
    }
  }
}
