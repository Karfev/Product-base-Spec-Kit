{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "audit-event.schema.json",
  "title": "AuditEvent",
  "description": "Schema for an audit log entry",
  "type": "object",
  "required": ["id", "timestamp", "user_id", "action_type", "resource_type", "resource_id"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "user_id": {
      "type": "string"
    },
    "action_type": {
      "type": "string",
      "enum": ["create", "update", "delete", "access", "auth"]
    },
    "resource_type": {
      "type": "string"
    },
    "resource_id": {
      "type": "string"
    },
    "source_ip": {
      "type": "string"
    },
    "metadata": {
      "type": "object"
    }
  }
}
