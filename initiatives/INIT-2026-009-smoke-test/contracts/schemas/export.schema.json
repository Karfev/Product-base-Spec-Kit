{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "export.schema.json",
  "title": "Export",
  "description": "Export project report entity",
  "type": "object",
  "required": ["id", "project_id", "format", "status", "created_at"],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "project_id": {
      "type": "string",
      "format": "uuid"
    },
    "format": {
      "type": "string",
      "enum": ["json", "csv"]
    },
    "status": {
      "type": "string",
      "enum": ["pending", "processing", "completed", "failed"]
    },
    "download_url": {
      "type": ["string", "null"],
      "format": "uri"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "completed_at": {
      "type": ["string", "null"],
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
